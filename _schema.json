{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Client Partnership Roadmap (Hatch v3)",
  "description": "Per-client roadmap consumed by Hatch dashboards. v3 splits state from action: subtitle_how = current situation, next_action = explicit next step. NEVER include revenue, opp_size, or Sales-internal context.",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "stream_name",
      "theme",
      "status",
      "meta_owner",
      "client_owner",
      "subtitle_why",
      "subtitle_how",
      "next_action",
      "sort_order"
    ],
    "properties": {
      "stream_name": {
        "type": "string"
      },
      "subtitle_why": {
        "type": "string",
        "description": "Business rationale (why this matters)."
      },
      "subtitle_how": {
        "type": "string",
        "description": "Current state / situation (where we are now)."
      },
      "next_action": {
        "type": "string",
        "description": "Explicit next step (verb-led). Use empty string only for Done items with no follow-up."
      },
      "theme": {
        "type": "string"
      },
      "status": {
        "enum": [
          "Open",
          "In Progress",
          "Blocked",
          "Done"
        ]
      },
      "meta_owner": {
        "type": "string"
      },
      "client_owner": {
        "type": "string"
      },
      "sort_order": {
        "type": "integer"
      },
      "deadline": {
        "type": "string"
      },
      "link_url": {
        "type": "string"
      },
      "tags": {
        "type": "string"
      },
      "pinned": {
        "type": "boolean"
      }
    }
  }
}